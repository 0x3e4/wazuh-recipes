# Environment for the PowerShell / LOLBins weekly digest service.
# Copy to /etc/powershell-lolbins-digest.env, fill in, then:
#   chown wazuh-recipes:wazuh-recipes /etc/powershell-lolbins-digest.env && chmod 600 /etc/powershell-lolbins-digest.env
# Keeping secrets here (not on the command line / not in the script) keeps them
# out of `ps`, the unit file, and version control.

# Required: password of a (read-only) Wazuh Indexer user.
INDEX_PASSWORD=changeme

# Where opensearch-py is importable from (the venv usually has it on sys.path
# already; set this only if you install the library to a shared directory).
#WAZUH_RECIPES_LIB=/opt/wazuh-recipes/lib

# Optional overrides (defaults shown):
#INDEX_URL=https://127.0.0.1:9200
#INDEX_USER=admin
#INDEX_PATTERN=wazuh-alerts-*
#CA=/etc/filebeat/certs/root-ca.pem
#NO_VERIFY=0                         # set 1 to skip indexer TLS verification (localhost)
#SMTP_SERVER=smtp.example.com
#MAIL_FROM=wazuh@example.com
#RECIPIENTS=security@example.com     # comma-separated; or pass --recipients
#RANGE_DAYS=7                        # how many days back each weekly run summarises
#DASHBOARD_URL=https://wazuh.example.com   # link printed in the email

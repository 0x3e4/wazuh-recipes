# Environment for the Entra/Intune admin config-change digest service.
# Copy to /opt/entra-config-changes-digest/entra-config-changes.env, fill in, then:
#   chown wazuh-recipes:wazuh-recipes <file> && chmod 600 <file>
# Keeping secrets here (not on the command line / not in the script) keeps them out
# of `ps`, the unit file, and version control.

# Required: password of a (read-only) Wazuh Indexer user.
INDEX_PASSWORD=changeme

# Required ONLY for the Entra directoryAudit half: the Global-Admin role lookup via
# Microsoft Graph. App registration granted the APPLICATION permission
# RoleManagement.Read.Directory (admin consent). The Intune half needs none of this.
#MS_GRAPH_TENANT_ID=
#MS_GRAPH_CLIENT_ID=
#MS_GRAPH_SECRET=

# Optional overrides (defaults shown):
#INDEX_URL=https://127.0.0.1:9200
#INDEX_USER=admin
#INDEX_PATTERN=wazuh-alerts-4.x-*
#CA=/etc/wazuh-indexer/certs/root-ca.pem
#NO_VERIFY=0                              # set 1 to skip indexer TLS verification (localhost)
#SMTP_SERVER=smtp.example.com             # or --smtp-server on the ExecStart line
#SMTP_PORT=25                             # or --smtp-port
#MAIL_FROM=wazuh@example.com
#RECIPIENTS=security@example.com          # or keep --recipients on the ExecStart line
#DASHBOARD_URL=https://wazuh.example.com
#LOOKBACK_HOURS=24                        # how far back each run scans (dedup covers overlap)
#STATE_DB=/opt/entra-config-changes-digest/state.db
#SUPPRESS_NOISE=1                         # drop opaque .NET placeholder property values
#GRAPH_ROLE_CACHE_HOURS=6                 # how long the Global-Admin member set is cached
#GLOBAL_ADMIN_ROLE_TEMPLATE_IDS=62e90394-69f5-4237-9190-012177145e10  # add ids to widen

# mTLS instead of a password (point at a readable client cert/key; e.g. run as root
# with the indexer admin cert). Leave unset to use INDEX_PASSWORD.
#INDEX_CLIENT_CERT=/etc/wazuh-indexer/certs/admin.pem
#INDEX_CLIENT_KEY=/etc/wazuh-indexer/certs/admin-key.pem

# Where opensearch-py is importable from (usually already on the venv's sys.path).
#WAZUH_RECIPES_LIB=/opt/wazuh-recipes/lib

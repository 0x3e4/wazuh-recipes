[Unit]
Description=Run the Wazuh Entra/Intune admin config-change check every 15 minutes

[Timer]
# The ms-graph integration polls Microsoft Graph every ~10 min, so a 15-min
# cadence is near-real-time. Dedup (SQLite) makes the lookback overlap harmless.
OnCalendar=*:0/15
RandomizedDelaySec=60
Persistent=true

[Install]
WantedBy=timers.target

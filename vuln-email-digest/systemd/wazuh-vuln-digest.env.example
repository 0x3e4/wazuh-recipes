# Environment for the digest service. Copy to /opt/wazuh-vuln-digest/wazuh-vuln-digest.env,
# fill in, then: chown wazuh-vuln:wazuh-vuln <file> && chmod 600 <file>
# Keeping secrets here (not on the command line / not in the script) keeps them out
# of `ps`, the unit file, and version control.

# Required: password of a (read-only) Wazuh Indexer user.
WAZUH_INDEXER_PASSWORD=changeme

# Optional overrides (defaults shown):
#WAZUH_INDEXER_USER=admin
#SMTP_SERVER=smtp.example.com
#MAIL_FROM=wazuh@example.com
#WAZUH_DASHBOARD=https://wazuh.example.com
#DIGEST_RECIPIENTS=security@example.com
#DIGEST_SEVERITY=Critical,High          # empty/unset = all severities

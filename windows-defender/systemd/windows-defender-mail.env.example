# Environment for the antivirus detection email digest (shared by the windows-defender and
# clamav recipes -- av_alert_digest.py). Copy to /opt/antivirus-mail/antivirus-mail.env,
# fill in, chmod 600, chown wazuh-recipes:wazuh-recipes.
# systemd EnvironmentFile has NO inline '# ...' comments after a value.

# Required: password of a (read-only) Wazuh Indexer user.
INDEX_PASSWORD=changeme

# Which detections to mail: defender | clamav | both
AV_SOURCE=defender

# Optional overrides (defaults shown):
#INDEX_URL=https://127.0.0.1:9200
#INDEX_USER=admin
#INDEX_PATTERN=wazuh-alerts-4.x-*
#CA=/etc/wazuh-indexer/certs/root-ca.pem
#NO_VERIFY=0
#SMTP_SERVER=smtp.example.com
#SMTP_PORT=25
#MAIL_FROM=wazuh@example.com
#RECIPIENTS=security@example.com
#LOOKBACK_HOURS=24
#STATE_DB=/opt/antivirus-mail/defender-state.db
#DASHBOARD_URL=https://wazuh.example.com
# mTLS instead of a password (readable client cert/key):
#INDEX_CLIENT_CERT=/etc/wazuh-indexer/certs/admin.pem
#INDEX_CLIENT_KEY=/etc/wazuh-indexer/certs/admin-key.pem
